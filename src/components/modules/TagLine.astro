---
import Picture from '@components/util/ImgComponent_01.astro';
// import { Image } from 'astro:assets';
import Img_1 from '@images/img_07.jpg';
import Img_1Sp from '@images/img_07_sp.jpg';
---

<section class="mainSection g-mainSection js-toggleClass" id="tagLine">
  <div class="scene style_01">
    <div class="inner">
      <div class="bgImg">
        <figure>
          <Picture pc={Img_1} sp={Img_1Sp} alt="" loading="eager" />
        </figure>
      </div>
      <!-- /.bgImg -->
      <div class="content g-mrgStyle_02">
        <div class="inner">
          <div class="summary g-summaryStyle_01 sp">
            <p>
              「CARRY YOUR DISCOVERY」、直訳すると“発見を持ち運べ”。 <br
              />しかし、発見はこれから出会うもの。一見矛盾した言葉だが、そこに意味がある。<br
              />BRIEFINGのターゲットは、好奇心があり、人生をアクティブにする新しい発見を求める人。<br
              /> “CARRY”は、物理的な「運ぶ」という意味だけでなく、<br
              />彼らを発見へと「導く」という意味が込められている。<br
              />これは、自動車メーカーが「私たちはクルマではなく、モビリティをつくる」と語ったのと同じ。<br
              />BRIEFINGがつくるのはバッグではなく、人生を豊かにする発見へと導くギアなのだ。
            </p>
          </div>
          <!-- /.summary -->
          <h2 class="pageRead g-ttlStyle_01 style_01">
            <span class="style_02">人生をアクティブにする発見へ、</span>
            <span class="style_02">あなたを駆り立てる。</span>
          </h2>
          <!-- /.pageRead -->
          <p class="pageTtl g-ttlStyle_02 style_02">
            <span>CARRY</span>
            <span>YOUR</span>
            <span>DISCOVERY</span>
          </p>
          <!-- /.pageTtl -->
          <p class="pageTtl g-ttlStyle_02 style_01">
            <span>CARRY</span>
            <span>YOUR</span>
            <span>DISCOVERY</span>
          </p>
          <!-- /.pageTtl -->
        </div>
        <!-- /.inner -->
      </div>
      <!-- /.content -->
    </div>
    <!-- /.inner -->
  </div>
  <!-- /.scene -->
  <div class="scene style_02 stay" id="tagLineContent">
    <div class="inner">
      <div class="content g-mrgStyle_02">
        <div class="inner">
          <div class="summary g-summaryStyle_01">
            <p>
              「CARRY YOUR DISCOVERY」、直訳すると“発見を持ち運べ”。 <br
              />しかし、発見はこれから出会うもの。一見矛盾した言葉だが、そこに意味がある。<br
              />BRIEFINGのターゲットは、好奇心があり、人生をアクティブにする新しい発見を求める人。<br
              /> “CARRY”は、物理的な「運ぶ」という意味だけでなく、<br
              />彼らを発見へと「導く」という意味が込められている。<br
              />これは、自動車メーカーが「私たちはクルマではなく、モビリティをつくる」と語ったのと同じ。<br
              />BRIEFINGがつくるのはバッグではなく、人生を豊かにする発見へと導くギアなのだ。
            </p>
          </div>
          <!-- /.summary -->
        </div>
        <!-- /.inner -->
      </div>
      <!-- /.content -->
    </div>
    <!-- /.inner -->
  </div>
  <!-- /.scene-->
</section>
<!-- /.mainSection -->

<style lang="scss">
  @use 'sass:math';
  @use 'src/styles/global' as *;
  @use 'src/styles/utils' as *;
  ////////////////////
  // @media screen and (min-height: $breakH + 1px) {
  .scene {
    height: 100vh;
  }
  @media screen and (max-width: $break-point-middle-sp) {
    .scene {
      height: 100vh;
      &.style_02 {
        opacity: 0;
        height: 0;
      }
    }
  }
  // }
  ////////////////////
  // .bgImg {
  //   figure {
  //     &.style_02 {
  //       opacity: 0;
  //       :global(.is-scene_02) &,
  //       :global(.is-modal) & {
  //         opacity: 1;
  //       }
  //     }
  //   }
  // }
  ////////////////////
  .content {
    > .inner {
      :global(.is-modal) & {
        opacity: 0;
      }
    }
  }
  @media screen and (max-width: $break-point-middle-sp) {
    .content {
      align-items: flex-end;
      > .inner {
        position: relative;
        min-height: calc(100dvh - get_sp($grid_03));
        justify-content: center;
        gap: 0;
        :global(.scrollUp) & {
          transform: translateY(get_sp(30));
          // justify-content: flex-start;
        }
      }
    }
  }
  ////////////////////
  .bgImg {
    :global(.is-scene_02) & {
      opacity: 1;
      filter: brightness(0.3);
    }
  }
  ////////////////////
  @media screen and (min-width: $break-point-middle) {
    .pageRead {
      margin-bottom: math.div(160, 20) + em;
      transition: 0.6s;
      :global(.is-scene_02) & {
        // margin-bottom: math.div(265, 20) + em;
        margin-bottom: 260px;
      }
      // @media screen and (max-height: $breakH + px) {
      //   margin-bottom: math.div(240, 20) + em;
      // }
    }
  }
  @media screen and (max-width: $break-point-middle-sp) {
    .pageRead {
      transition: 0.3s;
      margin-bottom: get_sp(10);
      transition: 0.6s 0.7 + $wait + s;
      opacity: 0;
      :global(.is-scene_02.is-animation) & {
        opacity: 1;
      }
    }
  }
  ////////////////////
  @media screen and (min-width: $break-point-middle) {
    .pageTtl {
      position: absolute;
      left: 0;
      width: 100%;
      transition: 0.6s;
      top: calc(100vh - 1em);
      @include fz_vwpc(146);
      :global(.is-scene_02) & {
        $gap: math.div(130, 200) + em;
        top: calc(50% - #{$gap});
        @include fz_vwpcmin(70);
        @media screen and (max-height: $breakH + px) {
          top: math.div(126, $design-h) * 100vh;
          // top: math.div(20, $design-h) * 100vh;
        }
      }
      &.style_02 {
        display: none;
      }
      // @media screen and (max-height: $breakH + px) {
      //   top: math.div(126, $design-h) * 100vh;
      //   @include fz_vwpcmin(70);
      // }
    }
  }
  @media screen and (max-width: $break-point-middle-sp) {
    .pageTtl {
      transition: 0.3s;
      margin-bottom: get_sp(40);
      // :global(.is-animation) & {
      //   @include fz_vw(37);
      // }
      &.style_01 {
        position: absolute;
        top: 0;
        left: 0;
        opacity: 0;
        :global(.is-animation) & {
          opacity: 0;
        }
      }
      &.style_02 {
        display: block;
        // transform: translateY(get_sp(10));
        span {
          opacity: 0;
          transform: translateX(-0.2em);
          &:nth-child(1) {
            transition: 0.6s 0.3 + $wait + s;
          }
          &:nth-child(2) {
            transition: 0.6s 0.4 + $wait + s;
          }
          &:nth-child(3) {
            transition: 0.6s 0.5 + $wait + s;
          }
          :global(.is-scene_02.is-animation) & {
            opacity: 1;
            transform: translateX(0%);
          }
        }
        // > span {
        //   display: inline;
        // }
      }
    }
  }
  ////////////////////
  // @media screen and (min-height: $breakH + 1px) {
  @media screen and (max-width: $break-point-middle-sp) {
    .scene.style_02 {
      .content {
        opacity: 0;
        :global(.is-current.is-animation) & {
          opacity: 1;
        }
      }
    }
  }
  @media screen and (min-width: $break-point-middle) {
    .scene.style_02 {
      .content {
        opacity: 0;
        :global(.is-current.is-scene_02) & {
          opacity: 1;
        }
      }
    }
  }
  // }
  ////////////////////
  .summary {
    margin-bottom: math.div(64, 14) + em;
  }
  @media screen and (max-width: $break-point-middle-sp) {
    .summary {
      @include fz_vw(12);
      // letter-spacing: get_sp(-1);
      margin-bottom: 0;
      // margin-top: get_sp(130);
      transition: 0.6s 0.8 + $wait + s;
      opacity: 0;
      :global(.is-scene_02.is-animation) & {
        opacity: 1;
      }
      br {
        display: none;
      }
    }
  }
  ////////////////////
  @media screen and (min-width: $break-point-middle) {
  }
</style>
